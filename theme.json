{
	"$schema": "https://schemas.wp.org/wp/7.0/theme.json",
	"version": 3,
	"customTemplates": [],
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"customDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"gradients": [
				{
					"gradient": "linear-gradient(to top, rgba(8,28,38,0.72) 0%, rgba(8,28,38,0.28) 38%, rgba(8,28,38,0) 70%)",
					"name": "Image scrim",
					"slug": "scrim"
				}
			],
			"palette": [
				{
					"color": "#0E2E3F",
					"name": "Blue",
					"slug": "blue"
				},
				{
					"color": "#081C26",
					"name": "Blue Deep",
					"slug": "blue-deep"
				},
				{
					"color": "#245A76",
					"name": "Blue Mid",
					"slug": "blue-mid"
				},
				{
					"color": "#CBD8DE",
					"name": "Blue Tint",
					"slug": "blue-tint"
				},
				{
					"color": "#AB8E66",
					"name": "Gold",
					"slug": "gold"
				},
				{
					"color": "#8A7050",
					"name": "Gold Deep",
					"slug": "gold-deep"
				},
				{
					"color": "#F1EADE",
					"name": "Gold Tint",
					"slug": "gold-tint"
				},
				{
					"color": "#4A6454",
					"name": "Green",
					"slug": "green"
				},
				{
					"color": "#5B303D",
					"name": "Burgundy",
					"slug": "burgundy"
				},
				{
					"color": "#C66E4E",
					"name": "Terracotta",
					"slug": "terracotta"
				},
				{
					"color": "#EEECE6",
					"name": "Beige",
					"slug": "beige"
				},
				{
					"color": "#FDFCFA",
					"name": "Paper",
					"slug": "paper"
				},
				{
					"color": "#F6F4EF",
					"name": "Sand",
					"slug": "sand"
				},
				{
					"color": "#CFCBBF",
					"name": "Stone",
					"slug": "stone"
				},
				{
					"color": "#403D36",
					"name": "Ink",
					"slug": "ink"
				},
				{
					"color": "#161F28",
					"name": "Charcoal",
					"slug": "charcoal"
				}
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Subtle",
					"shadow": "0 2px 6px rgba(22, 31, 40, 0.07)",
					"slug": "subtle"
				},
				{
					"name": "Card",
					"shadow": "0 2px 14px rgba(14, 46, 63, 0.06)",
					"slug": "card"
				},
				{
					"name": "Raised",
					"shadow": "0 8px 24px rgba(22, 31, 40, 0.08)",
					"slug": "raised"
				},
				{
					"name": "Float",
					"shadow": "0 18px 48px rgba(22, 31, 40, 0.12)",
					"slug": "float"
				}
			]
		},
		"spacing": {
			"customSpacingSize": true,
			"spacingSizes": [
				{
					"name": "1 — XX-Small",
					"size": "0.5rem",
					"slug": "20"
				},
				{
					"name": "2 — X-Small",
					"size": "0.75rem",
					"slug": "30"
				},
				{
					"name": "3 — Small",
					"size": "1rem",
					"slug": "40"
				},
				{
					"name": "4 — Medium",
					"size": "1.5rem",
					"slug": "50"
				},
				{
					"name": "5 — Large",
					"size": "2rem",
					"slug": "60"
				},
				{
					"name": "6 — X-Large",
					"size": "3rem",
					"slug": "70"
				},
				{
					"name": "7 — XX-Large",
					"size": "4rem",
					"slug": "80"
				},
				{
					"name": "8 — Huge",
					"size": "6rem",
					"slug": "90"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Jost",
							"fontStyle": "italic",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/jost/jost-100-900-italic.ttf"
							]
						},
						{
							"fontFamily": "Jost",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/jost/jost-100-900-normal.ttf"
							]
						}
					],
					"fontFamily": "Jost",
					"name": "Jost",
					"slug": "jost"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"Nyght Serif\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/nyght-serif/nyght-serif-400-normal.ttf"
							]
						},
						{
							"fontFamily": "\"Nyght Serif\"",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/nyght-serif/nyght-serif-500-normal.ttf"
							]
						}
					],
					"fontFamily": "\"Nyght Serif\"",
					"name": "Nyght Serif",
					"slug": "nyght-serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.1875rem",
						"min": "1.0625rem"
					},
					"name": "Large",
					"size": "1.1875rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "1.75rem",
						"min": "1.5rem"
					},
					"name": "Extra Large",
					"size": "1.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "2.75rem",
						"min": "2.25rem"
					},
					"name": "Heading",
					"size": "2.75rem",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"max": "4.5rem",
						"min": "3rem"
					},
					"name": "Display",
					"size": "4.5rem",
					"slug": "display"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"border": {
					"radius": "4px"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nyght-serif)",
					"fontWeight": "500",
					"letterSpacing": "-0.01em"
				}
			},
			"core/pullquote": {
				"color": {
					"text": "var(--wp--preset--color--blue)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nyght-serif)",
					"fontStyle": "italic",
					"fontWeight": "500"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--gold)",
						"style": "solid",
						"width": "2px"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nyght-serif)",
					"fontStyle": "italic",
					"fontWeight": "500"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--gold)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nyght-serif)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "500"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--beige)",
			"text": "var(--wp--preset--color--ink)"
		},
		"elements": {
			"button": {
				":active": {
					"color": {
						"background": "var(--wp--preset--color--blue-deep)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--blue-mid)"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--blue-mid)"
					}
				},
				"border": {
					"radius": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--blue)",
					"text": "var(--wp--preset--color--paper)"
				},
				"spacing": {
					"padding": {
						"bottom": "0.75rem",
						"left": "1.5rem",
						"right": "1.5rem",
						"top": "0.75rem"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jost)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500",
					"letterSpacing": "0.04em"
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--stone)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--display)",
					"lineHeight": "1.08"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jost)",
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "500",
					"letterSpacing": "0",
					"lineHeight": "1.3"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--blue)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nyght-serif)",
					"fontStyle": "italic",
					"fontWeight": "400",
					"letterSpacing": "-0.01em",
					"lineHeight": "1.2"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--gold-deep)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--blue)"
				},
				"typography": {
					"textDecoration": "underline"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--50)",
			"padding": {
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--jost)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontWeight": "400",
			"letterSpacing": "0",
			"lineHeight": "1.5"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}